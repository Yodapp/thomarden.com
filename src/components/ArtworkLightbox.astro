<div
  class="artwork-lightbox"
  data-artwork-lightbox
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="artwork-lightbox-title"
  hidden
>
  <div class="artwork-lightbox-panel">
    <button class="artwork-lightbox-close" type="button" data-artwork-close aria-label="Close artwork">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6.4 5 12 10.6 17.6 5 19 6.4 13.4 12l5.6 5.6-1.4 1.4-5.6-5.6L6.4 19 5 17.6l5.6-5.6L5 6.4z" />
      </svg>
    </button>
    <img data-artwork-lightbox-image src="" alt="" />
    <p id="artwork-lightbox-title" data-artwork-lightbox-title></p>
  </div>
</div>

<script>
  const lightbox = document.querySelector('[data-artwork-lightbox]');

  if (lightbox instanceof HTMLElement) {
    const image = lightbox.querySelector('[data-artwork-lightbox-image]');
    const title = lightbox.querySelector('[data-artwork-lightbox-title]');
    const closeButton = lightbox.querySelector<HTMLElement>('[data-artwork-close]');
    const pageRegions = document.querySelectorAll<HTMLElement>('.site-header, main, .site-footer');
    let closeTimer = 0;
    let previousFocus: HTMLElement | null = null;

    document.body.append(lightbox);

    const setPageInactive = (inactive: boolean) => {
      pageRegions.forEach((region) => {
        region.inert = inactive;
        if (inactive) region.setAttribute('aria-hidden', 'true');
        else region.removeAttribute('aria-hidden');
      });
    };

    const finishClose = () => {
      window.clearTimeout(closeTimer);
      lightbox.classList.remove('is-open', 'is-closing');
      lightbox.hidden = true;
      lightbox.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('has-artwork-lightbox');
      setPageInactive(false);
      previousFocus?.focus();
    };

    const closeLightbox = () => {
      if (lightbox.hidden || lightbox.classList.contains('is-closing')) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        finishClose();
        return;
      }

      lightbox.classList.remove('is-open');
      lightbox.classList.add('is-closing');
      closeTimer = window.setTimeout(finishClose, 220);
    };

    document.querySelectorAll('[data-artwork-open]').forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.stopPropagation();

        const triggerImage = trigger.querySelector('img');
        if (!(triggerImage instanceof HTMLImageElement) || !(image instanceof HTMLImageElement)) return;

        const artworkTitle = trigger.getAttribute('data-artwork-title') || triggerImage.alt || 'Album artwork';
        image.src = triggerImage.currentSrc || triggerImage.src;
        image.alt = artworkTitle;
        if (title) title.textContent = artworkTitle;

        previousFocus = trigger instanceof HTMLElement ? trigger : null;
        lightbox.classList.remove('is-closing');
        lightbox.hidden = false;
        lightbox.setAttribute('aria-hidden', 'false');
        document.documentElement.classList.add('has-artwork-lightbox');
        setPageInactive(true);
        window.requestAnimationFrame(() => {
          lightbox.classList.add('is-open');
          closeButton?.focus();
        });
      });
    });

    closeButton?.addEventListener('click', closeLightbox);

    lightbox.addEventListener('click', (event) => {
      if (event.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (event) => {
      if (lightbox.hidden) return;
      if (event.key === 'Escape') closeLightbox();
      if (event.key === 'Tab') {
        event.preventDefault();
        closeButton?.focus();
      }
    });
  }
</script>
