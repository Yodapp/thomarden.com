---
import type { Track } from '@/data/album';

type Props = {
  albumTitle: string;
  albumCover: string;
  tracks: Track[];
};

const { albumTitle, albumCover, tracks } = Astro.props;
const artworks = [
  { id: 'artwork-album', title: `${albumTitle} album cover`, image: albumCover },
  ...tracks.map((track) => ({
    id: `artwork-track-${track.number}`,
    title: `${track.title} cover`,
    image: track.coverImage
  }))
];
---

{
  artworks.map((artwork) => (
    <div
      class="artwork-lightbox"
      id={artwork.id}
      role="dialog"
      aria-modal="true"
      aria-labelledby={`${artwork.id}-title`}
    >
      <div class="artwork-lightbox-panel">
        <a class="artwork-lightbox-close" href="#music" aria-label="Close artwork">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.4 5 12 10.6 17.6 5 19 6.4 13.4 12l5.6 5.6-1.4 1.4-5.6-5.6L6.4 19 5 17.6l5.6-5.6L5 6.4z" />
          </svg>
        </a>
        <img src={artwork.image} alt={artwork.title} />
        <p id={`${artwork.id}-title`}>{artwork.title}</p>
      </div>
    </div>
  ))
}
