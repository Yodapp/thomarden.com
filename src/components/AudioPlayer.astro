---
import type { Track } from '@/data/album';

type Props = {
  tracks: Track[];
  fallbackArtwork: string;
};

const { tracks, fallbackArtwork } = Astro.props;
const playableTracks = tracks.map((track) => ({
  number: track.number,
  title: track.title,
  audioUrl: track.audioUrl,
  coverImage: track.coverImage
}));
---

<section
  class="audio-player"
  data-audio-player
  data-tracks={JSON.stringify(playableTracks)}
  data-fallback-artwork={fallbackArtwork}
  style={`--track-artwork: url('${tracks[0]?.coverImage ?? fallbackArtwork}')`}
>
  <div class="player-main">
    <img class="player-artwork" data-artwork src={tracks[0]?.coverImage ?? fallbackArtwork} alt="" width="96" height="96" />
    <button class="play-button" type="button" data-play aria-label="Play selected track">▶</button>
    <div class="player-copy">
      <p class="player-title" data-title>{tracks[0]?.title ?? 'Select a track'}</p>
      <p class="player-subtitle" data-subtitle>
        {tracks[0]?.audioUrl ? 'Full track' : 'Audio unavailable'}
      </p>
    </div>
  </div>

  <div class="progress">
    <span data-current>0:00</span>
    <input data-progress type="range" min="0" max="100" value="0" aria-label="Track progress" />
    <span data-duration>0:00</span>
  </div>

  <audio data-audio preload="metadata"></audio>
</section>

<script>
  // @ts-nocheck
  const formatTime = (seconds) => {
    if (!Number.isFinite(seconds)) return '0:00';
    const minutes = Math.floor(seconds / 60);
    const rest = Math.floor(seconds % 60).toString().padStart(2, '0');
    return `${minutes}:${rest}`;
  };

  document.querySelectorAll('[data-audio-player]').forEach((player) => {
    const tracks = JSON.parse(player.getAttribute('data-tracks') || '[]');
    const audio = player.querySelector('[data-audio]');
    const playButton = player.querySelector('[data-play]');
    const title = player.querySelector('[data-title]');
    const subtitle = player.querySelector('[data-subtitle]');
    const progress = player.querySelector('[data-progress]');
    const current = player.querySelector('[data-current]');
    const duration = player.querySelector('[data-duration]');
    const artwork = player.querySelector('[data-artwork]');
    const fallbackArtwork = player.getAttribute('data-fallback-artwork') || '';
    const trackButtons = document.querySelectorAll('[data-track-play]');
    let selected = tracks[0];

    const updateTrackState = () => {
      trackButtons.forEach((button) => {
        const index = Number(button.getAttribute('data-track-play'));
        const isSelected = tracks[index]?.number === selected?.number;
        const isPlaying = isSelected && !audio.paused;
        const row = button.closest('[data-track-row]');

        row?.classList.toggle('is-selected', isSelected);
        row?.classList.toggle('is-playing', isPlaying);
        button.textContent = isPlaying ? 'Pause' : 'Play';
        button.setAttribute('aria-pressed', String(isPlaying));
      });
    };

    const updateArtwork = (track) => {
      if (!artwork) return;
      const imageUrl = track.coverImage || fallbackArtwork;
      artwork.onerror = () => {
        artwork.onerror = null;
        artwork.src = fallbackArtwork;
        player.style.setProperty('--track-artwork', `url('${fallbackArtwork}')`);
      };
      artwork.src = imageUrl;
      player.style.setProperty('--track-artwork', `url('${imageUrl}')`);
    };

    const loadTrack = (track) => {
      selected = track;
      title.textContent = track.title;
      updateArtwork(track);
      if (!track.audioUrl) {
        audio.removeAttribute('src');
        audio.load();
        playButton.textContent = '▶';
        subtitle.textContent = 'Audio unavailable';
        progress.value = 0;
        updateTrackState();
        return false;
      }

      audio.src = track.audioUrl;
      audio.load();
      subtitle.textContent = `Track ${track.number}`;
      updateTrackState();
      return true;
    };

    loadTrack(selected);

    document.querySelectorAll('[data-track-play]').forEach((button) => {
      button.addEventListener('click', async () => {
        const index = Number(button.getAttribute('data-track-play'));
        const track = tracks[index];
        if (!track) return;

        if (selected?.number === track.number && !audio.paused) {
          audio.pause();
          return;
        }

        if (selected?.number !== track.number && !loadTrack(track)) return;

        try {
          await audio.play();
          playButton.textContent = 'Ⅱ';
          updateTrackState();
        } catch {
          subtitle.textContent = 'Playback was blocked. Try pressing play again.';
        }
      });
    });

    playButton.addEventListener('click', async () => {
      if (!selected?.audioUrl) {
        subtitle.textContent = 'Audio unavailable';
        return;
      }

      if (audio.paused) {
        try {
          await audio.play();
          playButton.textContent = 'Ⅱ';
          updateTrackState();
        } catch {
          subtitle.textContent = 'Playback was blocked. Try pressing play again.';
        }
      } else {
        audio.pause();
        playButton.textContent = '▶';
        updateTrackState();
      }
    });

    audio.addEventListener('loadedmetadata', () => {
      duration.textContent = formatTime(audio.duration);
    });

    audio.addEventListener('timeupdate', () => {
      current.textContent = formatTime(audio.currentTime);
      progress.value = audio.duration ? String((audio.currentTime / audio.duration) * 100) : '0';
    });

    audio.addEventListener('ended', () => {
      playButton.textContent = '▶';
      updateTrackState();
    });

    audio.addEventListener('pause', updateTrackState);
    audio.addEventListener('play', updateTrackState);

    progress.addEventListener('input', () => {
      if (!audio.duration) return;
      audio.currentTime = (Number(progress.value) / 100) * audio.duration;
    });
  });
</script>
