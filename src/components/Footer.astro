---
import { socials } from '@/data/socials';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <a class="brand" href="/" aria-label="Thom Arden home">
        <span class="brand-mark" aria-hidden="true">TA</span>
        <span class="brand-name">Thom Arden</span>
      </a>
      <p class="muted">© {new Date().getFullYear()} Thom Arden. All rights reserved.</p>
    </div>

    <div>
      <div class="socials" aria-label="Social and streaming links">
        {socials.map((social) => <a class="social-link" href={social.href} aria-label={social.label}>{social.short}</a>)}
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/privacy/">Privacy</a>
        <a href="/contact/">Contact</a>
      </nav>
    </div>
  </div>
</footer>
