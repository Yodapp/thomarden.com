---
import { site } from '@/data/site';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-primary">
      <div class="footer-intro">
        <p class="eyebrow">Follow the story</p>
        <p class="footer-heading">Stay close to the music.</p>
      </div>

      <nav class="social-links" aria-label="Social media">
        {
          site.socialLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">
              <span>{link.label}</span>
              <span class="external-arrow" aria-hidden="true">↗</span>
            </a>
          ))
        }
      </nav>
    </div>

    <div class="footer-meta">
      <a class="footer-brand" href="/" aria-label="Thom Arden home">
        <span class="brand-mark" aria-hidden="true">TA</span>
        <span>Thom Arden</span>
      </a>

      <p class="footer-copyright">© {new Date().getFullYear()} Thom Arden</p>

      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/privacy/">Privacy</a>
        <a href="/contact/">Contact</a>
      </nav>
    </div>
  </div>
</footer>
