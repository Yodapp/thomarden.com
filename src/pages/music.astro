---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AudioPlayer from '@/components/AudioPlayer.astro';
import { album } from '@/data/album';
---

<BaseLayout title="Music" description="Listen to After the Silence by Thom Arden.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Music</p>
      <h1>After the <span>Silence</span></h1>
      <p class="lead">{album.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container album-grid">
      <div>
        <div class="album-cover">
          <img src={album.coverImage} alt={`${album.title} album cover`} />
        </div>
      </div>

      <div>
        <p class="eyebrow">{album.releaseNote}</p>
        <h2 class="section-title">{album.title}</h2>
        <p class="lead">Each song is a chapter — about finding beauty in what is broken, discovering that home can be a feeling, and choosing to begin again.</p>
        <p class="muted">{album.credits}</p>

        <AudioPlayer tracks={album.tracks} fallbackArtwork={album.coverImage} />

        <ol class="track-list">
          {
            album.tracks.map((track, index) => (
              <li class="track-row" data-track-row>
                <img class="track-artwork" src={track.coverImage} alt="" width="56" height="56" loading="lazy" />
                <div class="track-copy">
                  <p class="track-title">{track.title}</p>
                </div>
                <button
                  class="mini-button"
                  type="button"
                  data-track-play={index}
                  aria-label={`Play ${track.title}`}
                  aria-pressed="false"
                >
                  <svg class="control-icon control-icon-play" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5.5v13l10-6.5z" /></svg>
                  <svg class="control-icon control-icon-pause" viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 5.5h3.25v13H7.5zm5.75 0h3.25v13h-3.25z" /></svg>
                </button>
              </li>
            ))
          }
        </ol>

      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-header">
      <div>
        <p class="eyebrow">The Story Behind After the Silence</p>
        <h2 class="section-title">Ten songs. One story.</h2>
      </div>
      <p class="lead">
        From loss and uncertainty to hope, courage and new beginnings, <em>After the Silence</em> follows the quiet moments that ask us to take the next step.
      </p>
    </div>
  </section>

</BaseLayout>
