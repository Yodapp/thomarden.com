---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AudioPlayer from '@/components/AudioPlayer.astro';
import { album } from '@/data/album';
import { socials } from '@/data/socials';
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-inner">
      <div>
        <p class="eyebrow">Official artist website</p>
        <h1>Thom <span>Arden</span></h1>
        <p class="lead">
          Cinematic songs for the quiet after the storm — built around the debut album <em>{album.title}</em>.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/music/">Listen Now</a>
          <a class="button button-secondary" href="#story">Explore the Album</a>
        </div>
      </div>

      <aside class="hero-card" aria-label="Featured album">
        <div class="album-cover">
          <img src={album.coverImage} alt={`${album.title} album cover placeholder`} />
        </div>
        <div class="hero-card-content">
          <p class="eyebrow">{album.releaseNote}</p>
          <h2>{album.title}</h2>
          <p>{album.intro}</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section" id="listen">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">The album</p>
          <h2 class="section-title">After the Silence</h2>
        </div>
        <p class="lead">{album.story}</p>
      </div>

      <div class="album-grid">
        <div class="album-cover">
          <img src={album.coverImage} alt={`${album.title} album cover placeholder`} />
        </div>
        <div>
          <ol class="track-list">
            {
              album.tracks.map((track, index) => (
                <li class="track-row">
                  <span class="track-number">{String(track.number).padStart(2, '0')}</span>
                  <div>
                    <p class="track-title">{track.title}</p>
                    <span class="track-meta">Full track placeholder</span>
                  </div>
                  <button class="mini-button" type="button" data-track-play={index}>Play</button>
                </li>
              ))
            }
          </ol>

          <AudioPlayer tracks={album.tracks} />
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="story">
    <div class="container story-panel">
      <div class="glass-card">
        <p class="eyebrow">The story behind the album</p>
        <h3>From stillness into light.</h3>
        <p class="muted">
          This first version leaves room for the real story text, photography and video language to arrive.
          The structure is already in place for a cinematic album narrative without turning the site into a heavy app.
        </p>
      </div>
      <div class="glass-card">
        <p class="eyebrow">Coming next</p>
        <h3>Spotify and YouTube ready.</h3>
        <p class="muted">
          Streaming and social icons are already present as placeholders. Replace the links when the profiles,
          releases and videos go live.
        </p>
        <div class="socials">
          {socials.map((social) => <a class="social-link" href={social.href} aria-label={social.label}>{social.short}</a>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">First impression</p>
          <h2 class="section-title">A quiet, cinematic world.</h2>
        </div>
        <p class="lead">
          The design is intentionally restrained: deep shadows, warm gold, space for images, and enough motion to feel alive without getting in the way.
        </p>
      </div>

      <div class="feature-grid">
        <article class="feature-card">
          <h3>Music first</h3>
          <p class="muted">The album and its tracks are the center of the site, with room for full lyrics on the music page.</p>
        </article>
        <article class="feature-card">
          <h3>No noise</h3>
          <p class="muted">No newsletter, cookies, CMS or complex backend in the first version. Just the artist, the album and the atmosphere.</p>
        </article>
        <article class="feature-card">
          <h3>Ready to grow</h3>
          <p class="muted">YouTube videos, Cloudflare Web Analytics and Cloudflare R2 audio can be added without redesigning the site.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
