---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AudioPlayer from '@/components/AudioPlayer.astro';
import { album } from '@/data/album';
import { socials } from '@/data/socials';
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-inner">
      <div>
        <p class="eyebrow">Official artist website</p>
        <h1>Thom <span>Arden</span></h1>
        <p class="lead">
          Cinematic songs for the quiet after the storm — built around the debut album <em>{album.title}</em>.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/music/">Listen Now</a>
          <a class="button button-secondary" href="#story">Explore the Album</a>
        </div>
      </div>

      <aside class="hero-card" aria-label="Featured album">
        <div class="album-cover">
          <img src={album.coverImage} alt={`${album.title} album cover`} />
        </div>
        <div class="hero-card-content">
          <p class="eyebrow">{album.releaseNote}</p>
          <h2>{album.title}</h2>
          <p>{album.intro}</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section" id="listen">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">The album</p>
          <h2 class="section-title">After the Silence</h2>
        </div>
        <p class="lead">{album.story}</p>
      </div>

      <div class="album-grid">
        <div class="album-cover">
          <img src={album.coverImage} alt={`${album.title} album cover`} />
        </div>
        <div>
          <AudioPlayer tracks={album.tracks} fallbackArtwork={album.coverImage} />

          <ol class="track-list">
            {
              album.tracks.map((track, index) => (
                <li class="track-row" data-track-row>
                  <span class="track-number">{String(track.number).padStart(2, '0')}</span>
                  <img class="track-artwork" src={track.coverImage} alt="" width="64" height="64" loading="lazy" />
                  <div>
                    <p class="track-title">{track.title}</p>
                    <span class="track-meta">Full track</span>
                  </div>
                  <button class="mini-button" type="button" data-track-play={index} aria-pressed="false">Play</button>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="story">
    <div class="container story-panel">
      <div class="glass-card">
        <p class="eyebrow">The story behind the album</p>
        <h3>From silence to a new beginning.</h3>
        <p class="muted">
          There are moments when everything becomes quiet — not because the world has stopped, but because we are searching for the strength to take the next step.
        </p>
      </div>
      <div class="glass-card">
        <p class="eyebrow">Ten songs. One story.</p>
        <h3>Hope, healing, new beginnings.</h3>
        <p class="muted">
          Each song traces a journey from loss and uncertainty to courage, hope and the possibility of beginning again.
        </p>
        <div class="socials">
          {socials.map((social) => <a class="social-link" href={social.href} aria-label={social.label}>{social.short}</a>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">The journey</p>
          <h2 class="section-title">Broken can still be beautiful.</h2>
        </div>
        <p class="lead">
          After the Silence is more than a collection of songs. It is a reminder that another chapter is always waiting to be written.
        </p>
      </div>

      <div class="feature-grid">
        <article class="feature-card">
          <h3>Broken Beautiful</h3>
          <p class="muted">Even the things we carry can hold their own kind of beauty.</p>
        </article>
        <article class="feature-card">
          <h3>Home</h3>
          <p class="muted">Home is not always a place. Sometimes, it is a feeling we find again.</p>
        </article>
        <article class="feature-card">
          <h3>One More Sunrise</h3>
          <p class="muted">Every sunrise offers another chance to begin again.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
