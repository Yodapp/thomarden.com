---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy" description="Privacy information for thomarden.com.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy <span>notice.</span></h1>
      <p class="lead">
        A short overview of how thomarden.com handles information.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container glass-card" style="padding: 32px;">
      <h2>Information collection</h2>
      <p class="muted">
        This website does not use cookies, analytics scripts, newsletters or on-site contact forms. If you choose to email Thom Arden,
        your message is handled by your email provider and the recipient.
      </p>
    </div>
  </section>
</BaseLayout>
