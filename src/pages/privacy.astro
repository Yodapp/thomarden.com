---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy" description="Privacy information for thomarden.com.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy <span>notice.</span></h1>
      <p class="lead">
        Placeholder privacy page for the first release. No newsletter, cookies or analytics script are active in this version.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container glass-card" style="padding: 32px;">
      <h2>Current first-version setup</h2>
      <p class="muted">
        This website is currently planned as a static informational site. The contact form is not connected,
        no newsletter is active, and no cookie-based tracking has been added. Cloudflare Web Analytics may be added later.
      </p>
    </div>
  </section>
</BaseLayout>
