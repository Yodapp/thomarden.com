---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Videos" description="Official visual releases from Thom Arden.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Videos</p>
      <h1>Visuals for the <span>music.</span></h1>
      <p class="lead">
        A home for official music videos, lyric films and behind-the-scenes moments.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container glass-card" style="padding: 32px;">
      <p class="eyebrow">Visual releases</p>
      <h2 class="section-title">Music made to be seen.</h2>
      <p class="muted">Official visual releases will be collected here as they are shared.</p>
    </div>
  </section>
</BaseLayout>
