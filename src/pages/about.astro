---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Thom Arden and the cinematic world behind the music.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>The quiet after <span>the storm.</span></h1>
      <p class="lead">
        Thom Arden is a cinematic music project shaped around emotional storytelling, warm darkness and songs that feel like scenes from a film.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container story-panel">
      <article class="glass-card">
        <p class="eyebrow">Artist statement</p>
        <h3>Songs for memory, distance and return.</h3>
        <p class="muted">
          Replace this placeholder with the final biography when it is ready. The tone should stay intimate,
          elegant and direct — less press release, more invitation into the world of the album.
        </p>
      </article>
      <article class="glass-card">
        <p class="eyebrow">Visual world</p>
        <h3>Ocean light, silhouettes, warm shadows.</h3>
        <p class="muted">
          This layout is ready for real portraits, album artwork and atmospheric photography once the image direction is chosen.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
