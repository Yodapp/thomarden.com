---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';
---

<BaseLayout title="Contact" description="Contact Thom Arden for music, press and collaboration inquiries.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Start a <span>conversation.</span></h1>
      <p class="lead">
        For music, press and collaboration inquiries, get in touch by email.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-card">
      <p class="eyebrow">Email</p>
      <h2 class="section-title">Get in touch.</h2>
      <p class="muted">Please include a little context about your inquiry.</p>
      <a class="button button-primary" href={`mailto:${site.email}`}>{site.email}</a>
    </div>
  </section>
</BaseLayout>
